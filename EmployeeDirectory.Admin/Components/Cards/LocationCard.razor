@using EmployeeDirectory.Core.Data.Context
@using EmployeeDirectory.Core.Models
@using Microsoft.EntityFrameworkCore
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using Telerik.Blazor.Data
@using Telerik.Blazor.Extensions
@using Telerik.Blazor.Services
@using Telerik.SvgIcons
@using Telerik.DataSource
@using Telerik.DataSource.Extensions

@inject AppDbContext dbContext

<TelerikWindow @ref="LocInfoWindow"
               Modal="true"
               @bind-Visible="@WindowVisible"
               Width="400px"
               Height="auto"
               Resizable="false"
               Draggable="false"
               Class="user-card"
               CloseOnOverlayClick="true">

    <WindowTitle>
        @if (SelectedLocation != null)
        {
            <h3>@SelectedLocation.LocName</h3>
        }
    </WindowTitle>

    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>

    <WindowContent>
        @if (SelectedLocation != null)
        {
            <section>
                <div>
                    <div class="card-row">
                        <label>Location Number:</label>
                        <TelerikTextBox Value="@SelectedLocation.LocNum.ToString()"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Street Address:</label>
                        <TelerikTextBox Value="@SelectedLocation.Address"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>City:</label>
                        <TelerikTextBox Value="@SelectedLocation.City"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>State:</label>
                        <TelerikTextBox Value="@SelectedLocation.State"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Zipcode:</label>
                        <TelerikTextBox Value="@SelectedLocation.Zipcode"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Phone Number:</label>
                        @if (SelectedLocation.PhoneNumber != null)
                        {
                            <FormatPhone PhoneNumber="@SelectedLocation.PhoneNumber" PhoneNumClass="bold-phone" />
                        }
                        else
                        {
                            <TelerikTextBox Value=""
                                            ReadOnly="true"
                                            FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                            Width="100%" />
                        }
                    </div>
                    <div class="card-row">
                        <label>Fax or Alt. Number:</label>
                        @if (SelectedLocation.FaxNumber != null)
                        {
                            <FormatPhone PhoneNumber="@SelectedLocation.FaxNumber" PhoneNumClass="bold-phone" />
                        }
                        else
                        {
                            <TelerikTextBox Value=""
                                            ReadOnly="true"
                                            FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                            Width="100%" />
                        }
                    </div>
                    <div class="card-row">
                        <label>Email:</label>
                        <TelerikTextBox Value="@SelectedLocation.Email"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Hours:</label>
                        <TelerikTextBox Value="@SelectedLocation.Hours"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Location Type:</label>
                        <TelerikTextBox Value="@SelectedLocation.Loctype.GetDisplayName()"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Location Manager:</label>
                        <TelerikTextBox Value="@SelectedLocation.StoreManager"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Area Manager:</label>
                        <TelerikTextBox Value="@SelectedLocation.AreaManager"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Location Added:</label>
                        <TelerikTextBox Value="@(SelectedLocation.RecordAdd?.ToString("MM/dd/yyyy"))"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                </div>
            </section>
        }
    </WindowContent>

    <WindowFooter>
        <TelerikButton OnClick="() => WindowVisible = false"
                       ThemeColor="primary">
            Close
        </TelerikButton>
    </WindowFooter>

</TelerikWindow>

<style>
    .bold-phone {
        font-weight: 700;
        display: inline-flex;
        padding: 0;
    }

    section {
        padding: 4px;
    }

    .user-card {
        width: auto;
        height: auto;
        margin: 10px;
    }

        .user-card .k-input.k-readonly {
            font-weight: 600;
            font-size: 1em;
        }

        .user-card .k-window-titlebar-actions {
            background-color: var(--kendo-color-primary-emphasis);
        }

    .k-actions {
        background: var(--kendo-color-primary);
    }

    .card-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        padding: 0;
        margin: 8px;
        border: solid 1px;
        border-color: var(--kendo-color-primary);
    }

        .card-row label {
            padding: 8px 10px;
            margin-bottom: 0;
            font-weight: 500;
            font-size: 0.82em;
            text-transform: uppercase;
            background-color: var(--kendo-color-primary);
            color: white;
            white-space: nowrap;
            display: flex;
            align-items: center;
            min-width: 120px;
        }

        .card-row .k-input.k-input-flat {
            flex: 1;
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
        }

            .card-row .k-input.k-input-flat .k-input-inner {
                font-weight: 600;
                font-size: 1em;
                padding: 4px 8px;
            }
</style>

@code {
    private bool WindowVisible { get; set; }
    private Location? SelectedLocation { get; set; }
    private TelerikWindow? LocInfoWindow { get; set; }

    [Parameter]
    public List<Department> Departments { get; set; } = new();

    public void ShowLocationInfo(Location location)
    {
        SelectedLocation = location;
        WindowVisible = true;
        StateHasChanged();
    }

    private string GetWindowTitle()
    {
        return SelectedLocation != null
            ? $"{SelectedLocation.LocName} {SelectedLocation.LocNum} - Details"
            : "Location Information";
    }

    private void OpenWindow()
    {
        WindowVisible = true;
    }
}