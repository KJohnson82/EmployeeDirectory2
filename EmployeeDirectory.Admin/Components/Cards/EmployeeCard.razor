@* ===================================================================== *@
@* EMPLOYEE DETAILS MODAL COMPONENT                                      *@
@* Displays comprehensive employee information in a popup window         *@
@* ===================================================================== *@

@using EmployeeDirectory.Core.Data.Context
@using EmployeeDirectory.Core.Models
@using Microsoft.EntityFrameworkCore
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using Telerik.Blazor.Data
@using Telerik.Blazor.Extensions
@using Telerik.Blazor.Services
@using Telerik.SvgIcons
@using Telerik.DataSource
@using Telerik.DataSource.Extensions

@inject AppDbContext dbContext

<TelerikWindow @ref="EmpInfoWindow"
               Modal="true"
               @bind-Visible="@WindowVisible"
               Width="400px"
               Height="auto"
               MinHeight="500px"
               Resizable="true"
               Draggable="false"
               Class="user-card"
               CloseOnOverlayClick="true">

    <WindowTitle>
        @if (SelectedEmployee != null)
        {
            <h3>@SelectedEmployee.FirstName @SelectedEmployee.LastName</h3>
        }
    </WindowTitle>

    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>

    <WindowContent>
        @if (SelectedEmployee != null)
        {
            <section>
                <div>
                    <div class="card-row">
                        <label>Job Title:</label>
                        <TelerikTextBox Value="@SelectedEmployee.JobTitle"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Is Manager:</label>
                        <TelerikTextBox Value="@(SelectedEmployee.IsManager == true ? "Yes" : "No")"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>

                    <div class="card-row">
                        <label>Phone Number:</label>
                        <FormatPhone PhoneNumber="@SelectedEmployee.PhoneNumber" PhoneNumClass="bold-phone" />
                    </div>

                    <div class="card-row">
                        <label>Alt. Number:</label>
                        @if (SelectedEmployee.CellNumber != null)
                        {
                            <FormatPhone PhoneNumber="@SelectedEmployee.CellNumber" PhoneNumClass="bold-phone" />
                        } else
                        {
                            <TelerikTextBox Value=""
                                            ReadOnly="true"
                                            FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                            Width="100%" />
                        }

                        @* <TelerikTextBox Value="@SelectedEmployee.CellNumber"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" /> *@
                    </div>
                    <div class="card-row">
                        <label>Extension:</label>
                        <TelerikTextBox Value="@SelectedEmployee.Extension"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Email:</label>
                        <TelerikTextBox Value="@SelectedEmployee.Email"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>

                    <div class="card-row">
                        <label>Network ID:</label>
                        <TelerikTextBox Value="@SelectedEmployee.NetworkId"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>

                    <div class="card-row">
                        <label>Department:</label>
                        <TelerikTextBox Value="@(Departments.FirstOrDefault(d => d.Id == SelectedEmployee.Department)?.DeptName)"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>

                    <div class="card-row">
                        <label>Location:</label>
                        <TelerikTextBox Value="@(Locations.FirstOrDefault(l => l.Id == SelectedEmployee.Location)?.LocName)"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>

                    <div class="card-row">
                        <label>Employee Added:</label>
                        <TelerikTextBox Value="@(SelectedEmployee.RecordAdd?.ToString("MM/dd/yyyy"))"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                </div>
            </section>
        }
    </WindowContent>

    <WindowFooter>
        <TelerikButton OnClick="() => WindowVisible = false"
                       ThemeColor="primary">
            Close
        </TelerikButton>
    </WindowFooter>

</TelerikWindow>

<style>
    label {
        padding: 8px 6px 6px 8px;
        margin-bottom: 15px;
        font-weight: 500;
        font-size: 0.9em;
        text-transform: uppercase;
        background-color: var(--kendo-color-primary);
        color: white;
    }

    .bold-phone {
        font-weight: 700;
        display: inline-flex;
        padding: 0;
    }

    section {
        padding: 4px;
    }

    .user-card {
        width: auto;
        height: auto;
        margin: 10px;
    }

        .user-card .k-input.k-readonly {
            font-weight: 600;
            font-size: 1em;
        }

        .user-card .k-window-titlebar-actions {
            background-color: var(--kendo-color-primary-emphasis);
        }

    .k-actions {
        background: var(--kendo-color-primary);
    }

    /* .card-row {
        padding: 4px 0;
        margin: 8px;
        border: solid 1px;
        border-color: var(--kendo-color-primary);
    } */

    /* Make card-row a horizontal flex container so label and textbox sit side-by-side */
    .card-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        padding: 0; /* remove the 4px 0 padding, let children handle it */
        margin: 8px;
        border: solid 1px;
        border-color: var(--kendo-color-primary);
    }


        /* Label takes fixed width and fills the row height */
        .card-row label {
            padding: 8px 10px;
            margin-bottom: 0; /* override the 15px margin-bottom */
            font-weight: 500;
            font-size: 0.82em;
            text-transform: uppercase;
            background-color: var(--kendo-color-primary);
            color: white;
            white-space: nowrap;
            display: flex;
            align-items: center;
            min-width: 120px;
        }

        /* Make the Telerik TextBox fill remaining space and remove its default border */
        .card-row .k-input.k-input-flat {
            flex: 1;
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
        }

            /* Style the text value inside the readonly textbox */
            .card-row .k-input.k-input-flat .k-input-inner {
                font-weight: 600;
                font-size: 1em;
                padding: 4px 8px;
            }

    /* Same treatment for your FormatPhone component row */
    .phone-card-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        border: solid 1px;
        border-color: var(--kendo-color-primary);
        padding: 0;
        margin: 8px;
    }

    argin: 8px;
    }
</style>

@code {
    private bool WindowVisible { get; set; }
    private Employee? SelectedEmployee { get; set; }
    private List<Employee> employees { get; set; } = new List<Employee>();
    private TelerikWindow? EmpInfoWindow { get; set; }

    [Parameter]
    public List<Location> Locations { get; set; } = new();

    [Parameter]
    public List<Department> Departments { get; set; } = new();

    public void ShowEmployeeInfo(Employee employee)
    {
        SelectedEmployee = employee;
        WindowVisible = true;
        StateHasChanged();
    }

    private string GetWindowTitle()
    {
        return SelectedEmployee != null
            ? $"{SelectedEmployee.FirstName} {SelectedEmployee.LastName} - Details"
            : "Employee Information";
    }

    private void OpenWindow()
    {
        WindowVisible = true;
    }
}