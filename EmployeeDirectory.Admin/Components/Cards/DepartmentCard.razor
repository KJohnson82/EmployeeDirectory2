@using EmployeeDirectory.Core.Data.Context
@using EmployeeDirectory.Core.Models
@using Microsoft.EntityFrameworkCore
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using Telerik.Blazor.Data
@using Telerik.Blazor.Extensions
@using Telerik.Blazor.Services
@using Telerik.SvgIcons
@using Telerik.DataSource
@using Telerik.DataSource.Extensions

@inject AppDbContext dbContext

<TelerikWindow @ref="DeptInfoWindow"
               Modal="true"
               @bind-Visible="@WindowVisible"
               Width="400px"
               Height="auto"
               Resizable="false"
               Draggable="false"
               Class="user-card"
               CloseOnOverlayClick="true">

    <WindowTitle>
        @if (SelectedDepartment != null)
        {
            <h3>@SelectedDepartment.DeptName</h3>
        }
    </WindowTitle>

    <WindowActions>
        <WindowAction Name="Close" />
    </WindowActions>

    <WindowContent>
        @if (SelectedDepartment != null)
        {
            <section>
                <div>
                    <div class="card-row">
                        <label>Department Location:</label>
                        <TelerikTextBox Value="@SelectedDepartment.DeptLocation?.LocName"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Department Manager:</label>
                        <TelerikTextBox Value="@SelectedDepartment.DeptManager"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Phone Number:</label>
                        @if (SelectedDepartment.DeptPhone != null)
                        {
                            <FormatPhone PhoneNumber="@SelectedDepartment.DeptPhone" PhoneNumClass="bold-phone" />
                        }
                        else
                        {
                            <TelerikTextBox Value=""
                                            ReadOnly="true"
                                            FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                            Width="100%" />
                        }
                    </div>
                    <div class="card-row">
                        <label>Department Fax:</label>
                        @if (SelectedDepartment.DeptFax != null)
                        {
                            <FormatPhone PhoneNumber="@SelectedDepartment.DeptFax" PhoneNumClass="bold-phone" />
                        }
                        else
                        {
                            <TelerikTextBox Value=""
                                            ReadOnly="true"
                                            FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                            Width="100%" />
                        }
                    </div>
                    <div class="card-row">
                        <label>Department Email:</label>
                        <TelerikTextBox Value="@SelectedDepartment.DeptEmail"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                    <div class="card-row">
                        <label>Department Added:</label>
                        <TelerikTextBox Value="@(SelectedDepartment.RecordAdd?.ToString("MM/dd/yyyy"))"
                                        ReadOnly="true"
                                        FillMode="@Telerik.Blazor.ThemeConstants.TextBox.FillMode.Flat"
                                        Width="100%" />
                    </div>
                </div>
            </section>
        }
    </WindowContent>

    <WindowFooter>
        <TelerikButton OnClick="() => WindowVisible = false"
                       ThemeColor="primary">
            Close
        </TelerikButton>
    </WindowFooter>

</TelerikWindow>

<style>
    .bold-phone {
        font-weight: 700;
        display: inline-flex;
        padding: 0;
    }

    section {
        padding: 4px;
    }

    .user-card {
        width: auto;
        height: auto;
        margin: 10px;
    }

        .user-card .k-input.k-readonly {
            font-weight: 600;
            font-size: 1em;
        }

        .user-card .k-window-titlebar-actions {
            background-color: var(--kendo-color-primary-emphasis);
        }

    .k-actions {
        background: var(--kendo-color-primary);
    }

    .card-row {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        padding: 0;
        margin: 8px;
        border: solid 1px;
        border-color: var(--kendo-color-primary);
    }

        .card-row label {
            padding: 8px 10px;
            margin-bottom: 0;
            font-weight: 500;
            font-size: 0.82em;
            text-transform: uppercase;
            background-color: var(--kendo-color-primary);
            color: white;
            white-space: nowrap;
            display: flex;
            align-items: center;
            min-width: 120px;
        }

        .card-row .k-input.k-input-flat {
            flex: 1;
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
        }

            .card-row .k-input.k-input-flat .k-input-inner {
                font-weight: 600;
                font-size: 1em;
                padding: 4px 8px;
            }
</style>

@code {
    private bool WindowVisible { get; set; }
    private Department? SelectedDepartment { get; set; }
    private TelerikWindow? DeptInfoWindow { get; set; }

    [Parameter]
    public List<Location> Locations { get; set; } = new();

    public void ShowDepartmentInfo(Department department)
    {
        SelectedDepartment = department;
        WindowVisible = true;
        StateHasChanged();
    }

    private string GetWindowTitle()
    {
        return SelectedDepartment != null
            ? $"{SelectedDepartment.DeptName} - Details"
            : "Department Information";
    }

    private void OpenWindow()
    {
        WindowVisible = true;
    }
}