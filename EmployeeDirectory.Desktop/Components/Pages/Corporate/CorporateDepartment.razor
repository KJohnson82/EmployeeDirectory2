@page "/corporate/{departmentID:int}"

@using EmployeeDirectory.Core.DTOs
@using EmployeeDirectory.Core.Services
@using EmployeeDirectory.Desktop.Components.Navigation
@using EmployeeDirectory.UI
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using Telerik.SvgIcons

@inject IDirectoryService DirectoryService
@inject NavigationManager NavigationManager
@inject LayoutState LayoutState

<PageTitle>Department</PageTitle>

@if (Department == null)
{
    <p>No Data Available...</p>
}
else
{
    <div class="button-page-container">
        <div class="scrollable-wrapper">
            <TelerikListView Data="@Department.Employees" EnableLoaderContainer="true" Class="button-list-container" Pageable="false">
                <Template Context="emp">
                    <NavLink href="@($"/corporate/{departmentID}/{emp.Id}")" class="nav-link-clean">
                        <div class="menu-item employee-list-item">
                            @* Employee name with manager star indicator *@
                            <div class="employee-name-row">
                                @emp.FirstName @emp.LastName
                                @if (emp.IsManager == true)
                                {
                                    <span class="manager-indicator">
                                        <TelerikSvgIcon Icon="@SvgIcon.Star" Size="@ThemeConstants.SvgIcon.Size.Large" />
                                    </span>
                                }
                            </div>
                            @* Employee job title *@
                            <div class="employee-title">@emp.JobTitle</div>
                        </div>
                    </NavLink>
                </Template>
            </TelerikListView>
        </div>
    </div>
}

<style>
    .nav-link-clean {
        text-decoration: none;
        text-transform: uppercase;
    }

    .employee-list-item {
        padding: 0.75rem 1rem;
        margin: 0.5rem 0;
        border-radius: 0.75rem;
        color: white;
        font-size: medium;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .employee-name-row {
        align-items: center;
    }

    .manager-indicator {
        color: var(--kendo-color-warning);
        padding-left: 0.25rem;
    }

    .employee-title {
        color: var(--kendo-color-dark);
        font-weight: bold;
        font-size: small;
    }

    .button-list-container {
        padding: 0 10px;
    }
</style>

@code {
    [Parameter]
    public int departmentID { get; set; }

    private DepartmentDto? Department;
    private HeaderCardModels.HeadInfoCardModel? DepartmentInfo;
    private List<FooterNav.FooterItem> FooterNav => FooterNavigation.CorporateSection;

    protected override async Task OnParametersSetAsync()
    {
        Department = await DirectoryService.GetDepartmentWithEmployeesAsync(departmentID);

        if (Department?.Employees != null)
        {
            Department.Employees = Department.Employees
                .OrderBy(e => e.FirstName)
                .ThenBy(e => e.LastName)
                .ToList();
        }

        if (Department != null)
        {
            DepartmentInfo = HeaderCardModels.ForDepartment(
                title: Department.DeptName ?? "Department",
                phone: Department.DeptPhone,
                email: Department.DeptEmail,
                manager: Department.DeptManager
            );
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && DepartmentInfo != null)
        {
            LayoutState.SetHeader(DepartmentInfo);
            LayoutState.SetFooter(FooterNavigation.CorporateSection);
        }
    }
}
