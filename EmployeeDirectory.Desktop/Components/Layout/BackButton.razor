@* Reusable back navigation button that uses browser history *@
@using Microsoft.JSInterop
@using Telerik.Blazor
@using Telerik.Blazor.Components
@using EmployeeDirectory.Desktop

@inject NavigationManager Navigation
@inject IJSRuntime JS

<TelerikButton OnClick="@GoBack"
               Icon="@CustomIcons.LeftArrow"
               Size="@ThemeConstants.Button.Size.Large"
               ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
               Class="k-py-2"
               FillMode="@ThemeConstants.Button.FillMode.Solid">
    @ChildContent
</TelerikButton>

@code {
    // Content to display inside the button (e.g., "Back" text)
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? FallbackUrl { get; set; } = "/";

    // Navigate back using browser history via JavaScript interop
    // private async Task GoBack()
    // {
    //     await JS.InvokeVoidAsync("goBack");
    // }
    private void GoBack()
    {
        // Navigate based on current route hierarchy
        var currentPath = Navigation.ToBaseRelativePath(Navigation.Uri);

        if (string.IsNullOrEmpty(currentPath) || currentPath == "/")
        {
            // Already at home, nowhere to go
            return;
        }

        // Go up one level in the URL path
        var segments = currentPath.TrimEnd('/').Split('/');

        if (segments.Length <= 1)
        {
            // At a top-level page, go home
            Navigation.NavigateTo("/");
        }
        else
        {
            // Remove last segment to go up one level
            var parentPath = string.Join("/", segments.Take(segments.Length - 1));
            Navigation.NavigateTo("/" + parentPath);
        }
    }
}